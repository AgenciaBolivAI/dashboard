{
  "_comment": "Single source of truth for health checks — read by lib/health/checks.ts (the /admin/health page) AND scripts/health-check.mjs (npm run health). Add here when a feature adds a critical table/column/pricing/env.",
  "tables": [
    "tenants", "users", "dashboard_users", "leads", "conversations", "chat_history",
    "reservations", "calendar_slots", "notifications", "ai_recommendations", "tasks",
    "credit_pricing", "credit_accounts", "credit_transactions",
    "assistant_messages", "prospect_research", "prospect_settings", "conversation_analysis",
    "aima_settings", "aima_scrape_runs", "marketing_campaigns", "marketing_messages",
    "lead_forms", "tenant_api_keys", "voice_conversations", "invoices"
  ],
  "columns": [
    ["assistant_messages", "session_id", "step75"],
    ["aima_settings", "email_enrichment_enabled", "step76"],
    ["prospect_settings", "auto_research_enabled", "step72"],
    ["prospect_research", "status", "step72"],
    ["conversation_analysis", "sentiment", "step73"],
    ["leads", "email", "core"],
    ["leads", "website", "core"],
    ["leads", "metadata", "core"]
  ],
  "pricing": [
    "research.prospect", "analysis.sentiment", "assistant.query",
    "marketing.email_broadcast", "marketing.whatsapp_broadcast", "marketing.sms_broadcast",
    "marketing.lead_scraped_google_maps"
  ],
  "env": [
    "NEXT_PUBLIC_SUPABASE_URL", "NEXT_PUBLIC_SUPABASE_ANON_KEY", "SUPABASE_SERVICE_ROLE_KEY",
    "OPENAI_API_KEY", "EVOLUTION_BASE_URL", "STRIPE_SECRET_KEY", "N8N_BASE_URL",
    "CCAVAI_WEBHOOK_SECRET", "CCAVAI_WEBHOOK_URL",
    "AIMA_WEBHOOK_URL", "AIMA_WEBHOOK_SECRET",
    "META_AGENT_WEBHOOK_URL", "VOICE_INBOUND_WEBHOOK_SECRET"
  ],
  "locales": ["en", "es", "pt", "fr", "it"],
  "_probes_comment": "Live reachability/validity probes — side-effect-free. 'registered' webhooks are hit WITHOUT auth on purpose: their first node is an auth guard that throws before doing any work, so a registered webhook returns 500 (not 404) and NOTHING runs. expect: 'ok'=2xx; 'registered'=any response except 404; 'reachable'=any HTTP response (no connection error).",
  "probes": [
    { "name": "OpenAI API key valid", "method": "GET", "url": "https://api.openai.com/v1/models", "authEnv": "OPENAI_API_KEY", "expect": "ok" },
    { "name": "Supabase REST", "method": "GET", "urlEnv": "NEXT_PUBLIC_SUPABASE_URL", "path": "/rest/v1/", "authEnv": "SUPABASE_SERVICE_ROLE_KEY", "apikey": true, "expect": "ok" },
    { "name": "n8n reachable", "method": "GET", "urlEnv": "N8N_BASE_URL", "path": "/healthz", "expect": "ok" },
    { "name": "Evolution API reachable", "method": "GET", "urlEnv": "EVOLUTION_BASE_URL", "expect": "reachable" },
    { "name": "AIMA webhook registered", "method": "POST", "urlEnv": "AIMA_WEBHOOK_URL", "expect": "registered" },
    { "name": "CCAVAI webhook registered", "method": "POST", "urlEnv": "CCAVAI_WEBHOOK_URL", "expect": "registered" }
  ]
}
