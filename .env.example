# ─── Supabase ────────────────────────────────────────────────────────
# From Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# ─── n8n REST API (Hostinger VPS) ────────────────────────────────────
# Generate an API key in n8n → Settings → API
N8N_BASE_URL=https://your-n8n-domain
N8N_API_KEY=YOUR_N8N_API_KEY

# ─── Evolution API ───────────────────────────────────────────────────
# Use the STABLE Traefik domain — never the raw IP:port (it's ephemeral and
# drifts, which breaks QR + n8n sends).
EVOLUTION_BASE_URL=https://evolution.srv1642711.hstgr.cloud
EVOLUTION_API_KEY=YOUR_EVOLUTION_API_KEY

# ─── Internal webhooks / shared secrets ──────────────────────────────
# Bearer for internal tick + render + calendar-sync routes (checkBearer).
CCAVAI_WEBHOOK_SECRET=YOUR_INTERNAL_SECRET
# n8n trigger webhooks (dashboard → n8n). URL is on the n8n VPS; secret is the bearer.
CCAVAI_WEBHOOK_URL=https://your-n8n-domain/webhook/ccavai
AIMA_WEBHOOK_URL=https://your-n8n-domain/webhook/aima
AIMA_WEBHOOK_SECRET=YOUR_INTERNAL_SECRET
VIRA_WEBHOOK_URL=https://your-n8n-domain/webhook/vira
VIRA_WEBHOOK_SECRET=YOUR_INTERNAL_SECRET

# ─── Voice (ElevenLabs + Twilio) ─────────────────────────────────────
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY
MASTER_SANDRA_AGENT_ID=
MASTER_REBECCA_AGENT_ID=
MASTER_SANDRA_VOICE_ID=
MASTER_REBECCA_VOICE_ID=
VOICE_TOOL_SECRET=YOUR_VOICE_TOOL_HMAC_SECRET
VOICE_INBOUND_WEBHOOK_SECRET=YOUR_INBOUND_SECRET

# ─── LLM (chat + embeddings) ─────────────────────────────────────────
# Every LLM call goes through lib/llm (the client factory). Default is OpenAI.
# OPENAI_API_KEY is the fallback key for both chat and embeddings.
OPENAI_API_KEY=sk-...
#
# Going self-hosted is a CONFIG FLIP, not a refactor: point LLM_CHAT_* at any
# OpenAI-compatible endpoint (Ollama http://localhost:11434/v1, vLLM, etc.) with
# a function-calling model (llama3.3 / qwen). Chat and embeddings are configured
# SEPARATELY: embeddings are dimension-locked to the pgvector columns
# (text-embedding-3-small = 1536), so you can self-host chat while keeping OpenAI
# embeddings. Changing the embed model means re-ingesting every vector.
# All are OPTIONAL — omit to use the OpenAI defaults shown below.
# LLM_CHAT_BASE_URL=https://api.openai.com/v1
# LLM_CHAT_MODEL=gpt-4o-mini
# LLM_CHAT_API_KEY=                # falls back to OPENAI_API_KEY
# LLM_EMBED_BASE_URL=https://api.openai.com/v1
# LLM_EMBED_MODEL=text-embedding-3-small
# LLM_EMBED_API_KEY=               # falls back to OPENAI_API_KEY

# ─── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe price IDs per plan (create in Stripe dashboard first)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_WHITELABEL=price_...

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
